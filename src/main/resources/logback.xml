<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Custom Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="fr.paralya.bot.LogFormater"/>
    </appender>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>